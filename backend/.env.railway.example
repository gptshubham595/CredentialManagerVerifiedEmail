NODE_ENV=production
PORT=8080

# Railway injects these when Postgres and Redis services are attached.
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

JWT_SECRET=replace-with-railway-secret-variable
JWT_EXPIRES_IN=15m
CORS_ORIGIN=*

FIREBASE_PROJECT_ID=movieapp-cdb85
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@movieapp-cdb85.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_SERVICE_ACCOUNT_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Keep strict in production. The dev parser is only for local request/response wiring.
DIGITAL_CREDENTIAL_TRUST_MODE=strict
