PORT=8080
NODE_ENV=development

# Railway provides DATABASE_URL/REDIS_URL when you add Postgres and Redis services.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/verified_credential
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
CORS_ORIGIN=*

# Firebase Admin. Prefer GOOGLE_APPLICATION_CREDENTIALS locally, or set these on Railway.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Strict by default. Use dev only while wiring UI before production SD-JWT verification is implemented.
DIGITAL_CREDENTIAL_TRUST_MODE=strict
